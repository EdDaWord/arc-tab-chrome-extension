{
  "manifest_version": 3,
  "name": "Arc Tabs",
  "version": "1.0.0",
  "description": "Auto-close stale tabs and eject new/link tabs from groups, Arc-style.",

  "permissions": ["tabs", "tabGroups", "storage", "alarms"],

  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },

  "action": {
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "options_ui": {
    "page": "src/options.html",
    "open_in_tab": true
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
